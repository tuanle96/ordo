{
    "name": "backend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "build": "nest build && tsc-alias -p tsconfig.build.json",
        "start": "node dist/main.js",
        "start:dev": "nest start --watch",
        "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" && tsc --noEmit -p tsconfig.json",
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.0",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/throttler": "^6.5.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "fast-xml-parser": "^5.2.5",
        "ioredis": "^5.7.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.13.10",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/parser": "^8.57.0",
        "eslint": "^10.0.3",
        "jest": "^30.2.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.8.2"
    }
}