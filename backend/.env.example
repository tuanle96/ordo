# ──────────────────────────────────────────────
# Ordo Backend — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1/mobile

# ── JWT Authentication ────────────────────────
# REQUIRED: Generate strong random secrets (e.g., `openssl rand -base64 64`)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_KEY_PREFIX=ordo

# ── Odoo Connection ──────────────────────────
ODOO_REQUEST_TIMEOUT_MS=15000
ODOO_SESSION_TTL_SECONDS=1800

# ── Rate Limiting ─────────────────────────────
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_TTL_SECONDS=60
AUTH_REFRESH_RATE_LIMIT=20
AUTH_REFRESH_RATE_TTL_SECONDS=60

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins (leave empty for default)
CORS_ALLOWED_ORIGINS=

# ── Request Limits ────────────────────────────
MOBILE_JSON_BODY_LIMIT_BYTES=3000000

# ── Docker ────────────────────────────────────
# Set to "1" when running inside Docker with Odoo containers
RUNNING_IN_DOCKER=